# Dev convenience env for `npm run dev` / `npm run start` in harness/.
#
# The harness requires SCENARIO_PATH to be set; production deployments
# must set it explicitly in their environment. This file is a local-
# development default pointing at the travel demo scenario. Safe to
# edit if you're working against a different scenario, or delete if
# you prefer to set SCENARIO_PATH in your shell.
#
# Not consumed in production — only referenced from harness/package.json
# scripts (via Node's --env-file flag).

SCENARIO_PATH=../scenario/travel

# Transport + bind defaults that match scripts/dev-all.ps1. Override in
# your shell or edit locally if you need a different port.
HARNESS_TRANSPORT=http
HARNESS_BIND=127.0.0.1
HARNESS_HTTP_PORT=9080
HARNESS_ALLOW_INSECURE_CONFIG_ONLY=true
