		{
			"id": "rule:exclude_returned_orders_from_revenue",
			"type": "Rule",
			"properties": {
				"category": "metrics",
				"severity": "critical",
				"guidance": "Always add WHERE status NOT IN ('returned', 'return_pending') when computing revenue, average order value, or payment method breakdowns. Only 'completed', 'shipped', and 'placed' orders represent real revenue.\n",
				"description": "Revenue metrics must exclude returned and return_pending orders."
			}
		},
		{
			"id": "rule:order_amount_equals_payment_sum",
			"type": "Rule",
			"properties": {
				"category": "data_quality",
				"severity": "critical",
				"guidance": "If you see a discrepancy between the order amount and the sum of payment columns, flag it as a data quality issue. Do not attempt to reconcile manually.\n",
				"description": "Order amount must equal the sum of its payment method amounts: credit_card_amount + coupon_amount + bank_transfer_amount + gift_card_amount = amount."
			}
		},
		{
			"id": "rule:net_revenue_definition",
			"type": "Rule",
			"properties": {
				"category": "metrics",
				"severity": "warning",
				"guidance": "When the user asks for \"revenue\" without qualification, default to net revenue (exclude returned/return_pending). Only use gross revenue when explicitly asked.\n",
				"description": "\"Net revenue\" means total_revenue minus returned orders. \"Gross revenue\" includes all orders regardless of status.\n"
			}
		},
		{
			"id": "rule:customer_type_classification",
			"type": "Rule",
			"properties": {
				"category": "metrics",
				"severity": "warning",
				"guidance": "When segmenting customers, use: CASE WHEN number_of_orders > 1 THEN 'returning' ELSE 'new' END. 71% of customers in this dataset are new, 29% are returning.\n",
				"description": "Customers are classified as \"new\" (1 order) or \"returning\" (2+ orders). Use number_of_orders to determine this.\n"
			}
		},
		{
			"id": "rule:lifetime_value_consistency",
			"type": "Rule",
			"properties": {
				"category": "data_quality",
				"severity": "critical",
				"guidance": "If a user asks for both customer LTV and order-level revenue, ensure the totals are consistent. Use the customers table for per-customer LTV and orders for order-level breakdowns.\n",
				"description": "customer_lifetime_value should equal the sum of order amounts for that customer. Cross-check when presenting LTV alongside order-level totals.\n"
			}
		},
		{
			"id": "rule:pii_customer_names",
			"type": "Rule",
			"properties": {
				"category": "privacy",
				"severity": "critical",
				"guidance": "Never include first_name or last_name in query results unless the user explicitly requests individual customer records. For aggregate analysis, group by customer_id or customer segments instead. The policy engine will block these columns in strict mode.\n",
				"description": "first_name and last_name are personally identifiable information (PII)."
			}
		},
		{
			"id": "rule:orders_require_time_filter",
			"type": "Rule",
			"properties": {
				"category": "query_patterns",
				"severity": "warning",
				"guidance": "When a user asks about \"recent\" or \"last month\" orders, translate to an explicit date range on order_date. The policy engine enforces this in strict mode.\n",
				"description": "The orders table is a fact table spanning 2018-01-01 to 2018-04-09. Always apply a time filter on order_date for bounded queries.\n"
			}
		},
		{
			"id": "rule:payment_method_breakdown",
			"type": "Rule",
			"properties": {
				"category": "query_patterns",
				"severity": "info",
				"guidance": "For payment method breakdown by order, use the orders table columns directly (faster, one row per order). For transaction-level analysis or counting payment transactions, use the stg_payments table joined to orders.\n",
				"description": "Payment data exists at two granularities: (1) orders table has pre-aggregated payment columns (credit_card_amount, coupon_amount, etc.), (2) stg_payments has individual payment rows with payment_method dimension.\n"
			}
		},
		{
			"id": "rule:split_payments",
			"type": "Rule",
			"properties": {
				"category": "data_quality",
				"severity": "info",
				"guidance": "When counting \"orders paid by credit card\", use orders WHERE credit_card_amount > 0 rather than counting distinct order_ids in stg_payments, as an order can use multiple payment methods.\n",
				"description": "Some orders have split payments across multiple methods. There are 113 payment transactions for 99 orders, meaning ~14 orders have split payments.\n"
			}
		},
		{
			"id": "rule:order_status_definitions",
			"type": "Rule",
			"properties": {
				"category": "domain",
				"severity": "info",
				"guidance": "For fulfillment analysis: active pipeline = placed + shipped. Completed = successfully delivered. Problem orders = returned + return_pending. Completion rate = completed / (completed + returned + return_pending).\n",
				"description": "Order statuses and their meanings: placed (order received, not yet shipped), shipped (in transit), completed (delivered), returned (customer returned the order), return_pending (return requested, not yet processed).\n"
			}
		},
		{
			"id": "class:PII",
			"type": "Classification",
			"properties": {
				"description": "Personally identifiable information \u00e2\u20ac\u201d names, emails, phone numbers",
				"tags": ["sensitive", "restricted"]
			}
		},
		{
			"id": "class:Financial",
			"type": "Classification",
			"properties": {
				"description": "Monetary values that require careful aggregation",
				"tags": ["financial"]
			}
		},
		{
			"id": "policy:root",
			"type": "Policy",
			"properties": {
				"pii_mode": "block",
				"max_rows": 200,
				"require_contract": false
			}
		}
